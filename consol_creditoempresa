# ── Mapas de referencia ─────────────────────────────────────────────────────
MES_MAP = {
    'en':('Ene',1),'fe':('Feb',2),'ma':('Mar',3),'ab':('Abr',4),
    'my':('May',5),'jn':('Jun',6),'jl':('Jul',7),'ag':('Ago',8),
    'se':('Sep',9),'oc':('Oct',10),'no':('Nov',11),'di':('Dic',12),
}

# Detección de tipo por prefijo del nombre de archivo y por contenido interno
TIPO_MAP_STEM = {
    'B-':'Banco','FIN-':'Financiera','FIN':'Financiera',
    'CM-':'Caja Municipal','CMAC':'Caja Municipal',
    'CR-':'Caja Rural','CRAC':'Caja Rural',
    'ED-':'Edpyme','EDPYME':'Edpyme',
}
# Detección por contenido de la primera celda de empresas encontrada
TIPO_MAP_CONTENT = {
    'CMAC':'Caja Municipal','CMCP':'Caja Municipal',
    'CRAC':'Caja Rural',
    'EC ':'Edpyme','EC\t':'Edpyme',
}

# Columnas de salida
COLUMNAS = [
    'Fecha','Tipo','Empresa',
    'C. Corp.','C. Gran. Emp.','C. Med. E.',
    'C. Peq. Emp.','C. Micr. Emp.',
    'C. Consumo Rev','C. Consumo No Rev',
    'C. Hip.','TC. Credito'
]

# Bloques en orden, con las palabras clave a buscar en el título del bloque
BLOCK_ORDER = [
    'corporativ',
    'grandes emp',
    'median',
    'pequeñ',
    'microemp',
    'consumo rev',
    'consumo no',
    'hipotec',
]
STOP_KWS = [
    'corporativ','grandes emp','median','pequeñ','microemp',
    'hipotec','consumo rev','consumo no','fuente:','nota :',
    'las definicion','no incluye','* a partir',
]

# ── Helpers ──────────────────────────────────────────────────────────────────
def clean_entity(name):
    name = str(name).strip()
    name = re.sub(r'\.\s*$', '', name)
    name = re.sub(r'\s+', ' ', name).strip()
    return name

def safe_float(v):
    if pd.isna(v) or str(v).strip() in ('-', '', 'nan'):
        return 0.0
    try:
        return float(v)
    except:
        return 0.0

def parse_filename(fp):
    """Devuelve (fecha_str, mes_num, anio) desde el nombre del archivo."""
    m = re.search(r'([a-z]{2})(\d{4})$', fp.stem.lower())
    if not m:
        return None, None, None
    mc = MES_MAP.get(m.group(1))
    if not mc:
        return None, None, None
    return f"{mc[0]}-{m.group(2)[2:]}", mc[1], int(m.group(2))

def detect_tipo_stem(fp):
    u = fp.stem.upper()
    for p, t in TIPO_MAP_STEM.items():
        if u.startswith(p):
            return t
    return None

def detect_tipo_content(df):
    """Detecta tipo mirando los primeros nombres de empresa en el archivo."""
    for i in range(min(30, len(df))):
        for j in range(min(5, df.shape[1])):
            val = str(df.iloc[i, j]).strip()
            for prefix, tipo in TIPO_MAP_CONTENT.items():
                if val.startswith(prefix):
                    return tipo
    return 'Otro'

