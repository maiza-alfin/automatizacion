                c.fill = PatternFill('solid', fgColor=C_SUB_BG)
        ws3.row_dimensions[3].height = 60

        # Datos EGP
        for ridx, row_data in enumerate(gyp_records, 4):
            moneda = row_data.get('Moneda', 'TOTAL')
