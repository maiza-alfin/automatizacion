    C_ALT2   = "FFFFFF"

    thin = Side(style='thin', color='CCCCCC')
    brd  = Border(left=thin, right=thin, top=thin, bottom=thin)

    MONEDA_COLOR = {'MN': C_MN_BG, 'ME': C_ME_BG, 'TOTAL': C_TOT_BG}

    # ── Hoja 1: CONSOLIDADO (formato ancho, con columna Moneda) ──
    ws = wb.active
    ws.title = "Consolidado"

    first_pasivo_col = None
    for i, col in enumerate(INDICATOR_COLS):
        if SECTIONS[col] == 'pasivo' and first_pasivo_col is None:
            first_pasivo_col = len(META_COLS) + i + 1

    # Fila 1: título
    ws.merge_cells(start_row=1, start_column=1, end_row=1, end_column=total_cols)
