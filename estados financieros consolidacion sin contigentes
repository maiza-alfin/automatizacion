def extract_gyp(file_path, tipo, fname_base):
    """Extrae la segunda hoja (Estado de Ganancias y Pérdidas)."""
    ext = os.path.splitext(file_path)[1].lower()
    if ext == '.xls':
        try:
            import xlrd  # noqa
        except ImportError:
            raise RuntimeError("Instala xlrd: pip install xlrd==1.2.0")
        all_sheets = pd.read_excel(file_path, sheet_name=None, header=None, engine='xlrd')
    else:
        all_sheets = pd.read_excel(file_path, sheet_name=None, header=None, engine='openpyxl')

    sheet_names = list(all_sheets.keys())
    if len(sheet_names) < 2:
        return [], None

    sh = all_sheets[sheet_names[1]]
    date = parse_date_from_sheet(sh) or parse_date_from_filename(fname_base)

    bank_row = sh.iloc[5].tolist()
    bank_cols = []
    for i, v in enumerate(bank_row):
        sv = str(v).strip()
        if sv and sv.lower() not in ('nan', ''):
            bank_cols.append((i, sv))

    # Canonicales únicos en orden (lista maestra sin duplicados)
    gyp_canonical_ordered = []
    seen_c = set()
    for raw, canonical, section in GYP_INDICATORS_ORDERED:
        if canonical not in seen_c:
            gyp_canonical_ordered.append(canonical)
            seen_c.add(canonical)

    # ── Tabla de secciones: encabezado_normalizado → código_sección ──
    SECTION_HEADERS = {
        re.sub(r'\s+',' ',h.strip()): code for h, code in [
            ('INGRESOS FINANCIEROS',              'IF'),
            ('GASTOS FINANCIEROS',                'GF'),
            ('MARGEN FINANCIERO BRUTO',           'MFB'),
            ('PROVISIONES PARA CRÉDITOS DIRECTOS','PCD'),
            ('MARGEN FINANCIERO NETO',            'MFN'),
            ('INGRESOS POR SERVICIOS FINANCIEROS','ISF'),
            ('GASTOS POR SERVICIOS FINANCIEROS',  'GSF'),
            ('UTILIDAD (PÉRDIDA) POR VENTA DE CARTERA',         'UPC'),
            ('UTILIDAD (PÉRDIDA) POR VENTA DE CARTERA CREDITICIA','UPC'),
            ('MARGEN OPERACIONAL',                'MO'),
            ('GASTOS ADMINISTRATIVOS',            'GA'),
            ('MARGEN OPERACIONAL NETO',           'MON'),
            ('PROVISIONES, DEPRECIACIÓN Y AMORTIZACIÓN','PDA'),
            ('OTROS INGRESOS Y GASTOS',           'OIG'),
            ('RESULTADO ANTES DE IMPUESTO A LA RENTA', 'RAIR'),
            ('RESULTADO ANTES DEL IMPUESTO A LA RENTA','RAIR'),
            ('IMPUESTO A LA RENTA',               'IR'),
            ('RESULTADO NETO DEL EJERCICIO',      'RNE'),
        ]
    }

    # ── Tabla de resolución: (sec_código, raw_normalizado) → canonical ──
    # Construida directamente desde GYP_INDICATORS_ORDERED recorriendo en orden.
    # Esto garantiza que "Fondos Interbancarios" en IF → canonical (IF)
    # y en GF → canonical (GF), sin ambigüedad.
    SEC_RAW_TO_CANONICAL = {}
    cur_sec = 'IF'
    for raw, canonical, section in GYP_INDICATORS_ORDERED:
        nraw = re.sub(r'\s+', ' ', raw.strip())
        # Si este raw es un encabezado, actualizar sección actual
        sec_code = SECTION_HEADERS.get(nraw)
        if sec_code:
            cur_sec = sec_code
        key = (cur_sec, nraw)
        if key not in SEC_RAW_TO_CANONICAL:
            SEC_RAW_TO_CANONICAL[key] = canonical

    # ── Recorrer la hoja asignando canonical usando (sección_actual, raw) ──
    cur_sec    = None
    ordered_rows = []   # lista de (ridx, canonical)

    for ridx in range(sh.shape[0]):
        raw  = str(sh.iloc[ridx, 0]).strip()
        if not raw or raw == 'nan':
            continue
        nraw = re.sub(r'\s+', ' ', raw)

        # Detectar cambio de sección
        sec_code = SECTION_HEADERS.get(nraw)
        if sec_code:
            cur_sec = sec_code

        # Resolver canonical por (sección, raw)
        canonical = None
        if cur_sec:
            canonical = SEC_RAW_TO_CANONICAL.get((cur_sec, nraw))
        # Fallback al lookup global (para encabezados de sección que son su propio canonical)
        if canonical is None:
            canonical = GYP_RAW_TO_CANONICAL.get(nraw)

        if canonical:
            ordered_rows.append((ridx, canonical))

    # ── Mapeo secuencial: target → ridx ──
    indicator_row_map = {}
    used_rows = set()
    for target in gyp_canonical_ordered:
        for ridx, cname in ordered_rows:
            if ridx in used_rows:
                continue
            if cname == target:
                indicator_row_map[target] = ridx
                used_rows.add(ridx)
                break

    def safe_float(v):
        try:
            return float(v) if pd.notna(v) else None
        except Exception:
            return None

    records = []
    for col_idx, bank_name in bank_cols:
        mn_col    = col_idx
        me_col    = col_idx + 1
        total_col = col_idx + 2
        ncols     = sh.shape[1]

        for moneda, col in [('MN', mn_col), ('ME', me_col), ('TOTAL', total_col)]:
            if col >= ncols:
                col = col_idx

            record = {
                'N°': None,
                'Fecha': date,
                'Tipo': tipo,
                'Entidad Financiera': bank_name.strip(),
                'Moneda': moneda,
            }

            for target in gyp_canonical_ordered:
                ridx = indicator_row_map.get(target)
                val = None
                if ridx is not None and col < ncols:
                    val = safe_float(sh.iloc[ridx, col])
                record[target] = val

            records.append(record)

    return records, date

