# INTERFAZ GRÁFICA (TKINTER)
# ============================================================
class App(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("Consolidador Balance General - SFP")
        self.geometry("680x520")
        self.resizable(False, False)
        self.configure(bg="#F0F4F8")
        self._build_ui()

    def _build_ui(self):
        # ── Encabezado ──
        hdr = tk.Frame(self, bg="#1F3864", height=70)
        hdr.pack(fill='x')
        tk.Label(hdr, text="Consolidador de Balance General",
                 font=("Arial", 16, "bold"), fg="white", bg="#1F3864").pack(pady=8)
        tk.Label(hdr, text="Sistema Financiero Peruano — SBS",
                 font=("Arial", 9), fg="#BDD7EE", bg="#1F3864").pack()

        body = tk.Frame(self, bg="#F0F4F8", padx=20, pady=15)
        body.pack(fill='both', expand=True)

        # ── Carpeta de entrada ──
        tk.Label(body, text="Carpeta con archivos XLS:", font=("Arial", 10, "bold"),
                 bg="#F0F4F8", anchor='w').grid(row=0, column=0, sticky='w', pady=(0, 4))

        self.input_var = tk.StringVar()
        input_frame = tk.Frame(body, bg="#F0F4F8")
        input_frame.grid(row=1, column=0, sticky='ew', pady=(0, 12))
        tk.Entry(input_frame, textvariable=self.input_var, width=55,
                 font=("Arial", 9)).pack(side='left', padx=(0, 8))
        tk.Button(input_frame, text="📂 Seleccionar", command=self._browse_input,
                  bg="#2E75B6", fg="white", font=("Arial", 9, "bold"),
                  padx=8, relief='flat').pack(side='left')

        # Tipos reconocidos
        tipos_frame = tk.LabelFrame(body, text=" Tipos de entidad reconocidos ",
                                    font=("Arial", 8), bg="#F0F4F8", fg="#555")
        tipos_frame.grid(row=2, column=0, sticky='ew', pady=(0, 12))
        tipos_text = "   ".join([f"{k} → {v}" for k, v in TIPO_MAP.items()])
        tk.Label(tipos_frame, text=tipos_text, font=("Arial", 8),
                 bg="#F0F4F8", fg="#333", wraplength=580, justify='left').pack(
                     padx=8, pady=4, anchor='w')

        # ── Archivo de salida ──
        tk.Label(body, text="Guardar consolidado en:", font=("Arial", 10, "bold"),
                 bg="#F0F4F8", anchor='w').grid(row=3, column=0, sticky='w', pady=(0, 4))

        self.output_var = tk.StringVar(
            value=os.path.join(os.path.expanduser("~"), "Desktop",
                               "Balance_General_Consolidado.xlsx"))
        out_frame = tk.Frame(body, bg="#F0F4F8")
        out_frame.grid(row=4, column=0, sticky='ew', pady=(0, 12))
        tk.Entry(out_frame, textvariable=self.output_var, width=55,
                 font=("Arial", 9)).pack(side='left', padx=(0, 8))
        tk.Button(out_frame, text="💾 Cambiar", command=self._browse_output,
                  bg="#375623", fg="white", font=("Arial", 9, "bold"),
                  padx=8, relief='flat').pack(side='left')

        body.columnconfigure(0, weight=1)

        # ── Botón principal ──
        self.btn_run = tk.Button(body, text="▶  GENERAR CONSOLIDADO",
                                 command=self._run,
                                 bg="#1F3864", fg="white",
                                 font=("Arial", 12, "bold"),
                                 padx=20, pady=10, relief='flat', cursor='hand2')
        self.btn_run.grid(row=5, column=0, pady=8)

        # ── Barra de progreso ──
        self.progress = ttk.Progressbar(body, mode='indeterminate', length=500)
        self.progress.grid(row=6, column=0, pady=(0, 8))

        # ── Log ──
        tk.Label(body, text="Registro de procesamiento:", font=("Arial", 9),
                 bg="#F0F4F8", anchor='w').grid(row=7, column=0, sticky='w')
        log_frame = tk.Frame(body, bg="#F0F4F8")
        log_frame.grid(row=8, column=0, sticky='nsew', pady=(4, 0))
        body.rowconfigure(8, weight=1)
        scrollbar = tk.Scrollbar(log_frame)
        scrollbar.pack(side='right', fill='y')
        self.log_box = tk.Text(log_frame, height=8, font=("Consolas", 8),
                               bg="#1E1E1E", fg="#D4D4D4",
                               yscrollcommand=scrollbar.set, wrap='word')
        self.log_box.pack(side='left', fill='both', expand=True)
        scrollbar.config(command=self.log_box.yview)

    def _browse_input(self):
        folder = filedialog.askdirectory(title="Seleccionar carpeta con archivos XLS")
        if folder:
            self.input_var.set(folder)

    def _browse_output(self):
        path = filedialog.asksaveasfilename(
            title="Guardar como",
            defaultextension=".xlsx",
            filetypes=[("Excel", "*.xlsx")],
            initialfile="Balance_General_Consolidado.xlsx"
        )
        if path:
            self.output_var.set(path)

    def _log(self, msg):
        self.log_box.insert('end', msg + '\n')
        self.log_box.see('end')
        self.update_idletasks()

    def _run(self):
        input_folder = self.input_var.get().strip()
        output_path  = self.output_var.get().strip()

        if not input_folder or not os.path.isdir(input_folder):
            messagebox.showerror("Error", "Selecciona una carpeta válida.")
            return
        if not output_path:
            messagebox.showerror("Error", "Indica dónde guardar el archivo de salida.")
            return

        self.log_box.delete('1.0', 'end')
        self.btn_run.config(state='disabled')
        self.progress.start(10)

        def _thread():
            consolidar(
                input_folder=input_folder,
                output_path=output_path,
                log_fn=self._log,
                done_fn=self._done
            )

        threading.Thread(target=_thread, daemon=True).start()

    def _done(self, ok, msg):
        self.progress.stop()
        self.btn_run.config(state='normal')
        if ok:
            self._log(f"\n✅ {msg}")
            messagebox.showinfo("¡Listo!", msg)
            # Abrir carpeta de salida
            out_dir = os.path.dirname(self.output_var.get())
            if os.path.isdir(out_dir):
                try:
                    os.startfile(out_dir)          # Windows
                except AttributeError:
                    subprocess.Popen(['xdg-open', out_dir])  # Linux/Mac
        else:
            self._log(f"\n❌ {msg}")
            messagebox.showerror("Error", msg)


