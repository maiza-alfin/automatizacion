        ws.cell(2, ci).fill = PatternFill('solid', fgColor=C_HDR_BG)
    first_activo_col = len(META_COLS) + 1
    ws.merge_cells(start_row=2, start_column=first_activo_col,
                   end_row=2, end_column=first_pasivo_col - 1)
