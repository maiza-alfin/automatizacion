        ws4.column_dimensions['D'].width = 32
        ws4.column_dimensions['E'].width = 8
        ws4.column_dimensions['F'].width = 60
        ws4.column_dimensions['G'].width = 22
        ws4.column_dimensions['H'].width = 18

    wb.save(output_path)

# ============================================================
# LÓGICA PRINCIPAL DE CONSOLIDACIÓN
# ============================================================
def consolidar(input_folder, output_path, log_fn, done_fn):
    """
    Ejecuta la consolidación completa.
    log_fn(msg) -> función para mostrar mensajes en la UI
    done_fn(ok, msg) -> función para notificar fin
    """
    xls_files = [
        f for f in os.listdir(input_folder)
        if f.lower().endswith('.xls') or f.lower().endswith('.xlsx')
    ]

    if not xls_files:
        done_fn(False, "No se encontraron archivos .xls / .xlsx en la carpeta seleccionada.")
        return

    all_records = []
    all_gyp     = []

    for fname in sorted(xls_files):
        fpath = os.path.join(input_folder, fname)
        fname_base = os.path.splitext(fname)[0]
        tipo = detect_tipo(fname_base)

        log_fn(f"📄 Procesando: {fname}  →  Tipo: {tipo}")

        try:
            records, date = extract_banks(fpath, tipo, fname_base)
            log_fn(f"   ✅ Balance: {len(records)//3} entidades  |  Fecha: {date}")
            all_records.extend(records)
        except Exception as e:
            log_fn(f"   ⚠️ Error Balance en {fname}: {e}")

        try:
            gyp_recs, date2 = extract_gyp(fpath, tipo, fname_base)
            if gyp_recs:
                log_fn(f"   ✅ EGP: {len(gyp_recs)//3} entidades  |  Fecha: {date2}")
                all_gyp.extend(gyp_recs)
        except Exception as e:
            log_fn(f"   ⚠️ Error EGP en {fname}: {e}")

    if not all_records:
        done_fn(False, "No se pudo extraer datos de ningún archivo.")
        return

    # Numerar Balance
    for i, r in enumerate(all_records, 1):
        r['N°'] = i

    # Numerar EGP
    for i, r in enumerate(all_gyp, 1):
        r['N°'] = i

    log_fn(f"\n📊 Balance: {len(all_records)} registros  |  EGP: {len(all_gyp)} registros")
    log_fn("💾 Generando Excel consolidado (4 hojas)...")

    try:
        build_excel(all_records, output_path, gyp_records=all_gyp)
    except Exception as e:
        done_fn(False, f"Error al guardar el Excel: {e}")
        return

    done_fn(True, f"¡Consolidado exitosamente!\nBalance: {len(all_records)} reg. | EGP: {len(all_gyp)} reg.\n→ {output_path}")


