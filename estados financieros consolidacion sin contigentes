def extract_banks(file_path, tipo, fname_base):
    sh = read_sheet(file_path)

    date = parse_date_from_sheet(sh) or parse_date_from_filename(fname_base)

    # Fila 5 = nombres de bancos
    bank_row = sh.iloc[5].tolist()
    SKIP = {'activo', 'pasivo', 'nan', ''}
    bank_cols = []
    for i, v in enumerate(bank_row):
        sv = str(v).strip()
        if sv.lower() not in SKIP and sv:
            bank_cols.append((i, sv))
    # Detectar filas de inicio de sección PASIVO y PATRIMONIO
    pasivo_start = None
    patrimonio_start = None

    for ridx in range(sh.shape[0]):
        val = str(sh.iloc[ridx, 0]).strip()
        val_upper = val.upper()
        if val_upper == 'PASIVO' and pasivo_start is None:
            pasivo_start = ridx
        elif 'PATRIMONIO' in val_upper and patrimonio_start is None:
            patrimonio_start = ridx

    # ============================================================
    # 🔥 NUEVO: CONTEXTO JERÁRQUICO (SOLUCIÓN REAL)
    # ============================================================
    context_stack = []
    ordered_rows = []

    for ridx in range(sh.shape[0]):
        raw = str(sh.iloc[ridx, 0]).strip()

        if not raw or raw == 'nan':
            continue

        canonical = get_canonical(raw)

        # FONDOS INTERBANCARIOS aparece en activo Y en pasivo con la misma etiqueta.
        # Si ya pasamos la fila de PASIVO, forzamos el canonical correcto.
        if (canonical == 'FONDOS INTERBANCARIOS'
                and pasivo_start is not None
                and ridx > pasivo_start):
            canonical = 'FONDOS INTERBANCARIOS (Pasivo)'

        if canonical:
            # Detectar si es cabecera (MAYÚSCULAS)
            if raw.isupper():
                # solo reinicia si es un encabezado real de sección
                if canonical in [
                    'ACTIVO',
                    'PASIVO',
                    'PATRIMONIO',
                    'OBLIGACIONES CON EL PÚBLICO',
                    'DEPÓSITOS DEL SISTEMA FINANCIERO Y ORGANISMOS INTERNACIONALES'
                ]:
                    context_stack = [canonical]
                else:
                    context_stack.append(canonical)
            else:
                # evitar duplicados consecutivos
                if not context_stack or context_stack[-1] != canonical:
                    context_stack.append(canonical)

            full_context = " > ".join(context_stack)
            ordered_rows.append((ridx, canonical, full_context))

    # ============================================================
    # 🔥 MAPEO INTELIGENTE (SIN PERDER "OTROS", "PROVISIONES", ETC.)
    # ============================================================
    canonical_ordered = [c for _, c, _ in INDICATORS_ORDERED]
    indicator_row_map = {}
    used_rows = set()

    for target in canonical_ordered:
        for ridx, cname, ctx in ordered_rows:
            if ridx in used_rows:
                continue

            matched = False

            # 🔥 CASOS ESPECÍFICOS (los que te fallaban)
            if target == 'Otros (Créditos Vigentes)' and 'Vigentes' in ctx:
                matched = True

            elif target == 'Provisiones (Créditos)' and 'CRÉDITOS' in ctx:
                matched = True

            elif (
                target == 'Otros (Depósitos a Plazo)'
                and 'OBLIGACIONES CON EL PÚBLICO' in ctx
                and 'Depósitos a Plazo' in ctx
                and 'Otros' in ctx
            ):
                matched = True

            elif target == 'Relacionadas con Inversiones' and 'Otras Obligaciones' in ctx:
                matched = True

            elif target == 'Depósitos a la Vista (SF)' and 'DEPÓSITOS DEL SISTEMA FINANCIERO' in ctx and 'Depósitos a la Vista' in ctx:
                matched = True

            elif target == 'Depósitos de Ahorro (SF)' and 'DEPÓSITOS DEL SISTEMA FINANCIERO' in ctx and 'Depósitos de Ahorro' in ctx:
                matched = True

            elif target == 'Depósitos a Plazo (SF)' and 'DEPÓSITOS DEL SISTEMA FINANCIERO' in ctx and 'Depósitos a Plazo' in ctx:
                matched = True

            elif (
                target == 'FONDOS INTERBANCARIOS (Pasivo)'
                and cname == 'FONDOS INTERBANCARIOS (Pasivo)'
                and pasivo_start is not None
                and patrimonio_start is not None
                and pasivo_start < ridx < patrimonio_start
            ):
                matched = True

            elif target == 'Fondos Interbancarios (Int.)' and 'GASTOS' in ctx:
                matched = True

            # 🔹 fallback normal
            elif cname == target:
                matched = True

            if matched:
                indicator_row_map[target] = ridx
                used_rows.add(ridx)
                break

    # ============================================================
    # EXTRACCIÓN POR BANCO (igual que antes)
    # ============================================================
    records = []
    def safe_float(v):
        try:
            return float(v) if pd.notna(v) else None
        except Exception:
            return None

    for col_idx, bank_name in bank_cols:
        mn_col    = col_idx
        me_col    = col_idx + 1
        total_col = col_idx + 2
        ncols     = sh.shape[1]

        # Genera 3 registros por banco: MN, ME, TOTAL
        for moneda, col in [('MN', mn_col), ('ME', me_col), ('TOTAL', total_col)]:
            if col >= ncols:
                col = col_idx  # fallback seguro

            record = {
                'N°': None,
                'Fecha': date,
                'Tipo': tipo,
                'Entidad Financiera': bank_name.strip(),
                'Moneda': moneda,
            }

            for target in canonical_ordered:
                ridx = indicator_row_map.get(target)
                val = None
                if ridx is not None and col < ncols:
                    val = safe_float(sh.iloc[ridx, col])
                record[target] = val

            records.append(record)

    return records, date
