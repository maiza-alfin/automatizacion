        ws3.freeze_panes = 'F4'
        ws3.auto_filter.ref = f"A3:{get_column_letter(gyp_total)}3"
        ws3.column_dimensions['A'].width = 5
        ws3.column_dimensions['B'].width = 9
        ws3.column_dimensions['C'].width = 15
        ws3.column_dimensions['D'].width = 32
        ws3.column_dimensions['E'].width = 8
        for ci in range(6, gyp_total + 1):
            ws3.column_dimensions[get_column_letter(ci)].width = 16

        # ── Hoja 4: EGP_Largo (formato SQL) ──
        ws4 = wb.create_sheet("EGP_Largo")
        SQL2_COLS = ['N°', 'Fecha', 'Tipo', 'Entidad Financiera', 'Moneda', 'Indicador', 'Seccion', 'Valor']

        ws4.merge_cells(start_row=1, start_column=1, end_row=1, end_column=len(SQL2_COLS))
        c = ws4.cell(1, 1, "ESTADO DE GANANCIAS Y PÉRDIDAS — FORMATO LARGO (para SQL)")
