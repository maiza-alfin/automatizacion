            'admin': 'Gastos Administrativos', 'provisiones': 'Provisiones/Depreciación',
            'resultado': 'Resultado',
        }
        seen_gyp_ind = {}
        for _, canonical, section in GYP_INDICATORS_ORDERED:
            if canonical not in seen_gyp_ind:
                seen_gyp_ind[canonical] = section

        sql2_row = 3
        for row_data in gyp_records:
            moneda = row_data.get('Moneda', 'TOTAL')
            row_bg = MONEDA_COLOR.get(moneda, C_ALT2)
            for canonical, section in seen_gyp_ind.items():
