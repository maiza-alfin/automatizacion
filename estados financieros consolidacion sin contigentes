def parse_date_from_sheet(sh):
    try:
        val = sh.iloc[2, 0]
        if pd.notna(val) and str(val) not in ('NaT', 'nan'):
            dt = pd.to_datetime(val)
            return dt.strftime('%Y%m')
    except Exception:
        pass
    return None

def parse_date_from_filename(fname_base):
    m = re.search(r'-([a-z]{2})(\d{4})$', fname_base, re.IGNORECASE)
    if m:
        mon = MONTH_MAP.get(m.group(1).lower(), '01')
        return f"{m.group(2)}{mon}"
    return 'DESCONOCIDA'

def detect_tipo(fname_base):
    """Detecta el tipo de entidad por el código del archivo."""
    for code, tipo in TIPO_MAP.items():
        if fname_base.upper().startswith(code):
            return tipo
    return 'Desconocido'

# ============================================================
# LECTURA DIRECTA XLS / XLSX (sin LibreOffice)
# ============================================================
def read_sheet(file_path):
    """
    Lee la primera hoja de un .xls o .xlsx directamente, sin conversión.
    - .xlsx  -> openpyxl  (incluido con pandas)
    - .xls   -> xlrd      (pip install xlrd==1.2.0)
    """
    ext = os.path.splitext(file_path)[1].lower()
    if ext == '.xls':
        try:
            import xlrd  # noqa
        except ImportError:
            raise RuntimeError(
                "Falta la librería 'xlrd' para leer archivos .xls.\n\n"
                "Instálala abriendo la terminal (CMD) y ejecutando:\n"
                "    pip install xlrd==1.2.0\n\n"
                "Luego vuelve a ejecutar el programa."
            )
        return pd.read_excel(file_path, sheet_name=0, header=None, engine='xlrd')
    else:
        return pd.read_excel(file_path, sheet_name=0, header=None, engine='openpyxl')


