    ALL_COLS     = META_COLS + INDICATOR_COLS
    total_cols   = len(ALL_COLS)

    C_HDR_BG = "1F3864"
    C_ACT_BG = "1F3864"
    C_PAS_BG = "375623"
    C_SEC_BG = "2E75B6"
    C_SUB_BG = "BDD7EE"
    C_SUB_FG = "1F3864"
