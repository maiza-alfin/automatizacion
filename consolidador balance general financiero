# ============================================================
# NORMALIZACIÓN DE ETIQUETAS
# ============================================================
def normalize(s):
    return re.sub(r'\s+', ' ', str(s).strip().rstrip('*'))

# Construir lookup normalizado desde INDICATORS_ORDERED
RAW_TO_CANONICAL = {}
for raw, canonical, section in INDICATORS_ORDERED:
    nraw = normalize(raw)
    if nraw not in RAW_TO_CANONICAL:
        RAW_TO_CANONICAL[nraw] = canonical

def get_canonical(raw_label):
    n = normalize(raw_label)
    if n in RAW_TO_CANONICAL:
        return RAW_TO_CANONICAL[n]
    stripped = raw_label.strip().rstrip('*').rstrip('/')
    if stripped in ALT_LABELS and ALT_LABELS[stripped] is not None:
        return ALT_LABELS[stripped]
    return None

# ============================================================
# PARSEO DE FECHA
# ============================================================
def parse_date_from_sheet(sh):
    try:
        val = sh.iloc[2, 0]
        if pd.notna(val) and str(val) not in ('NaT', 'nan'):
            dt = pd.to_datetime(val)
            return dt.strftime('%Y%m')
    except Exception:
        pass
    return None

def parse_date_from_filename(fname_base):
    m = re.search(r'-([a-z]{2})(\d{4})$', fname_base, re.IGNORECASE)
    if m:
        mon = MONTH_MAP.get(m.group(1).lower(), '01')
        return f"{m.group(2)}{mon}"
    return 'DESCONOCIDA'

def detect_tipo(fname_base):
    """Detecta el tipo de entidad por el código del archivo."""
    for code, tipo in TIPO_MAP.items():
        if fname_base.upper().startswith(code):
            return tipo
    return 'Desconocido'

# ============================================================
# CONVERSIÓN XLS → XLSX (usando LibreOffice si está disponible)
# ============================================================
def convert_xls_to_xlsx(xls_path, tmp_dir):
    """Convierte .xls a .xlsx y devuelve la ruta del .xlsx."""
    fname = os.path.splitext(os.path.basename(xls_path))[0]
    out_path = os.path.join(tmp_dir, fname + '.xlsx')
    if os.path.exists(out_path):
        return out_path
    # Buscar LibreOffice
    soffice = shutil.which('soffice') or shutil.which('libreoffice')
    if soffice:
        subprocess.run(
            [soffice, '--headless', '--convert-to', 'xlsx', xls_path, '--outdir', tmp_dir],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
        if os.path.exists(out_path):
            return out_path
    raise RuntimeError(
        f"No se pudo convertir {xls_path}.\n"
        "Instala LibreOffice para procesar archivos .xls:\n"
        "  https://www.libreoffice.org/download/download/"
    )

