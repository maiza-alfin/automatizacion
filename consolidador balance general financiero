# EXTRACCIÓN DE DATOS
# ============================================================
def extract_banks(xlsx_path, tipo, fname_base):
    sh = pd.read_excel(xlsx_path, sheet_name=0, header=None)

    date = parse_date_from_sheet(sh) or parse_date_from_filename(fname_base)

    # Fila 5 = nombres de bancos
    bank_row = sh.iloc[5].tolist()
    SKIP = {'activo', 'pasivo', 'nan', ''}
    bank_cols = []
    for i, v in enumerate(bank_row):
        sv = str(v).strip()
        if sv.lower() not in SKIP and sv:
            bank_cols.append((i, sv))

    # Construir ordered_rows: (row_idx, canonical) para toda la hoja
    ordered_rows = []
    for ridx in range(sh.shape[0]):
        raw = str(sh.iloc[ridx, 0])
        if raw.strip() and raw.strip() != 'nan':
            canonical = get_canonical(raw)
            if canonical:
                ordered_rows.append((ridx, canonical))

    # Mapear cada indicador de la lista maestra a su fila (respetando orden)
    canonical_ordered = [c for _, c, _ in INDICATORS_ORDERED]
    indicator_row_map = {}
    used_rows = set()
    for target in canonical_ordered:
        for ridx, cname in ordered_rows:
            if cname == target and ridx not in used_rows:
                indicator_row_map[target] = ridx
                used_rows.add(ridx)
                break

    # Extraer por banco
    records = []
    for col_idx, bank_name in bank_cols:
        total_col = col_idx + 2
        if total_col >= sh.shape[1]:
            total_col = col_idx

        record = {
            'N°': None,
            'Fecha': date,
            'Tipo': tipo,
            'Entidad Financiera': bank_name.strip(),
        }
        for target in canonical_ordered:
            ridx = indicator_row_map.get(target)
            val = None
            if ridx is not None and total_col < sh.shape[1]:
                raw_val = sh.iloc[ridx, total_col]
                try:
                    val = float(raw_val) if pd.notna(raw_val) else None
                except Exception:
                    val = None
            record[target] = val

        records.append(record)

    return records, date

