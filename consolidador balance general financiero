            c.fill = PatternFill('solid', fgColor=C_SEC_BG)
        else:
            c.font = Font(name='Arial', bold=True, size=8, color=C_SUB_FG)
            c.fill = PatternFill('solid', fgColor=C_SUB_BG)
    ws.row_dimensions[3].height = 60

    # Filas de datos
    for ridx, row_data in enumerate(all_records, 4):
        alt = C_ALT1 if ridx % 2 == 0 else C_ALT2
        for ci, col in enumerate(ALL_COLS, 1):
            val = row_data.get(col)
            c = ws.cell(ridx, ci, val)
            c.fill   = PatternFill('solid', fgColor=alt)
            c.border = brd
            if col == 'N°':
                c.alignment = Alignment(horizontal='center', vertical='center')
                c.font = Font(name='Arial', size=9)
            elif col in ('Fecha', 'Tipo'):
                c.alignment = Alignment(horizontal='center', vertical='center')
                c.font = Font(name='Arial', size=9)
            elif col == 'Entidad Financiera':
                c.alignment = Alignment(horizontal='left', vertical='center')
                c.font = Font(name='Arial', bold=True, size=9)
            else:
                c.alignment = Alignment(horizontal='right', vertical='center')
                c.font = Font(name='Arial', size=9)
                if isinstance(val, float) and val is not None:
                    c.number_format = '#,##0.00;(#,##0.00);"-"'
        ws.row_dimensions[ridx].height = 15

    # Freeze, filtros y anchos
    ws.freeze_panes = 'E4'
    ws.auto_filter.ref = f"A3:{get_column_letter(total_cols)}3"

    ws.column_dimensions['A'].width = 5
    ws.column_dimensions['B'].width = 9
    ws.column_dimensions['C'].width = 15
    ws.column_dimensions['D'].width = 32
    for ci in range(5, total_cols + 1):
        ws.column_dimensions[get_column_letter(ci)].width = 16

    wb.save(output_path)

# ============================================================
# LÓGICA PRINCIPAL DE CONSOLIDACIÓN
# ============================================================
def consolidar(input_folder, output_path, log_fn, done_fn):
    """
    Ejecuta la consolidación completa.
    log_fn(msg) -> función para mostrar mensajes en la UI
    done_fn(ok, msg) -> función para notificar fin
    """
    tmp_dir = os.path.join(input_folder, '_tmp_xlsx')
    os.makedirs(tmp_dir, exist_ok=True)

    xls_files = [
        f for f in os.listdir(input_folder)
        if f.lower().endswith('.xls') or f.lower().endswith('.xlsx')
    ]

    if not xls_files:
        done_fn(False, "No se encontraron archivos .xls / .xlsx en la carpeta seleccionada.")
        return

    all_records = []

    for fname in sorted(xls_files):
        fpath = os.path.join(input_folder, fname)
        fname_base = os.path.splitext(fname)[0]
        tipo = detect_tipo(fname_base)

        log_fn(f"📄 Procesando: {fname}  →  Tipo: {tipo}")

        try:
            # Convertir si es .xls
            if fname.lower().endswith('.xls'):
                xlsx_path = convert_xls_to_xlsx(fpath, tmp_dir)
            else:
                xlsx_path = fpath

            records, date = extract_banks(xlsx_path, tipo, fname_base)
            log_fn(f"   ✅ {len(records)} entidades extraídas  |  Fecha: {date}")
            all_records.extend(records)

        except Exception as e:
            log_fn(f"   ⚠️ Error en {fname}: {e}")

    if not all_records:
        done_fn(False, "No se pudo extraer datos de ningún archivo.")
        return

    # Numerar
    for i, r in enumerate(all_records, 1):
        r['N°'] = i

    log_fn(f"\n📊 Total de registros: {len(all_records)}")
    log_fn("💾 Generando Excel consolidado...")

    try:
        build_excel(all_records, output_path)
    except Exception as e:
        done_fn(False, f"Error al guardar el Excel: {e}")
        return

    # Limpiar tmp
    shutil.rmtree(tmp_dir, ignore_errors=True)

    done_fn(True, f"¡Consolidado exitosamente!\n{len(all_records)} entidades → {output_path}")


