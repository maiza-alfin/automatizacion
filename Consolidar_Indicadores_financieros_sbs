        self.title("Consolidador Indicadores SBS")
        self.geometry("760x600")
        self.resizable(True, True)
        self.configure(bg="#F0F4F8")
        self.archivos: list[str] = []
        self._build_ui()

    def _build_ui(self):
        # Header
        hdr = tk.Frame(self, bg="#1F3864", pady=14)
        hdr.pack(fill="x")
        tk.Label(hdr, text="Consolidador de Indicadores Financieros SBS",
                 font=("Arial", 15, "bold"), bg="#1F3864", fg="white").pack()
        tk.Label(hdr,
                 text="Bancos  |  Financieras  |  Cajas Municipales  |  Cajas Rurales  |  EDPYMEs",
                 font=("Arial", 9), bg="#1F3864", fg="#A8C4E0").pack(pady=(2, 0))

        body = tk.Frame(self, bg="#F0F4F8", padx=20, pady=14)
        body.pack(fill="both", expand=True)

        # Archivos
        frm_top = tk.LabelFrame(body, text=" Archivos XLS a consolidar ",
                                font=("Arial", 10, "bold"),
                                bg="#F0F4F8", fg="#1F3864", padx=10, pady=8)
        frm_top.pack(fill="x", pady=(0, 10))

        btn_row = tk.Frame(frm_top, bg="#F0F4F8")
        btn_row.pack(fill="x", pady=4)
        for txt, cmd in [
            ("  Agregar archivos XLS", self.agregar_archivos),
            ("  Agregar carpeta",      self.agregar_carpeta),
        ]:
            tk.Button(btn_row, text=txt, command=cmd,
                      bg="#2E75B6", fg="white", font=("Arial", 10, "bold"),
                      relief="flat", padx=12, pady=6, cursor="hand2"
                      ).pack(side="left", padx=(0, 8))
        tk.Button(btn_row, text="  Limpiar lista", command=self.limpiar_lista,
                  bg="#C0392B", fg="white", font=("Arial", 10),
                  relief="flat", padx=10, pady=6, cursor="hand2"
                  ).pack(side="right")

        lf = tk.Frame(frm_top, bg="#F0F4F8")
        lf.pack(fill="both", expand=True, pady=4)
        sb = ttk.Scrollbar(lf)
        sb.pack(side="right", fill="y")
        self.listbox = tk.Listbox(lf, yscrollcommand=sb.set, height=8,
                                  font=("Consolas", 9), bg="white", fg="#333",
                                  selectbackground="#2E75B6", relief="flat",
                                  borderwidth=1, highlightthickness=1,
                                  highlightbackground="#CCCCCC")
        self.listbox.pack(fill="both", expand=True)
        sb.config(command=self.listbox.yview)
        self.lbl_count = tk.Label(frm_top, text="0 archivos cargados",
                                   font=("Arial", 9), bg="#F0F4F8", fg="#666")
        self.lbl_count.pack(anchor="w")

        # Salida
        frm_out = tk.LabelFrame(body, text=" Archivo de salida ",
                                font=("Arial", 10, "bold"),
                                bg="#F0F4F8", fg="#1F3864", padx=10, pady=8)
        frm_out.pack(fill="x", pady=(0, 10))
        out_row = tk.Frame(frm_out, bg="#F0F4F8")
        out_row.pack(fill="x")
        default = os.path.join(os.path.expanduser("~"), "indicadores_consolidados.xlsx")
        self.var_output = tk.StringVar(value=default)
        tk.Entry(out_row, textvariable=self.var_output, font=("Arial", 9),
                 relief="flat", borderwidth=1, highlightthickness=1,
                 highlightbackground="#CCCCCC"
                 ).pack(side="left", fill="x", expand=True, padx=(0, 8))
        tk.Button(out_row, text="...", command=self.elegir_salida,
                  bg="#5D6D7E", fg="white", font=("Arial", 10),
                  relief="flat", padx=10, cursor="hand2").pack(side="right")

        # Log
        frm_log = tk.LabelFrame(body, text=" Log ",
                                font=("Arial", 10, "bold"),
                                bg="#F0F4F8", fg="#1F3864", padx=10, pady=6)
        frm_log.pack(fill="both", expand=True, pady=(0, 10))
        self.log_text = tk.Text(frm_log, height=6, font=("Consolas", 8),
                                bg="#1E1E1E", fg="#D4D4D4", relief="flat",
                                state="disabled")
        self.log_text.pack(fill="both", expand=True)

        tk.Button(body, text="   CONSOLIDAR",
                  command=self.consolidar,
                  bg="#1D6F42", fg="white", font=("Arial", 12, "bold"),
                  relief="flat", padx=20, pady=10, cursor="hand2").pack(fill="x")

    # ── Helpers UI ────────────────────────────────────────────────────────────
    def log(self, msg):
        self.log_text.config(state="normal")
        self.log_text.insert("end", f"  {msg}\n")
        self.log_text.see("end")
        self.log_text.config(state="disabled")
        self.update()

    def agregar_archivos(self):
        files = filedialog.askopenfilenames(
            title="Seleccionar archivos XLS",
            filetypes=[("Excel .xls", "*.xls"), ("Excel .xlsx", "*.xlsx"), ("Todos", "*.*")]
        )
        for f in files:
            if f not in self.archivos:
                self.archivos.append(f)
                self.listbox.insert("end", os.path.basename(f))
        self.lbl_count.config(text=f"{len(self.archivos)} archivos cargados")

    def agregar_carpeta(self):
        folder = filedialog.askdirectory(title="Seleccionar carpeta con archivos XLS")
        if not folder:
            return
        for fname in sorted(os.listdir(folder)):
            if fname.lower().endswith((".xls", ".xlsx")):
                full = os.path.join(folder, fname)
                if full not in self.archivos:
                    self.archivos.append(full)
                    self.listbox.insert("end", fname)
        self.lbl_count.config(text=f"{len(self.archivos)} archivos cargados")

    def limpiar_lista(self):
        self.archivos = []
        self.listbox.delete(0, "end")
        self.lbl_count.config(text="0 archivos cargados")

    def elegir_salida(self):
        path = filedialog.asksaveasfilename(
            defaultextension=".xlsx",
            filetypes=[("Excel", "*.xlsx")],
            initialfile="indicadores_consolidados.xlsx"
        )
        if path:
            self.var_output.set(path)

    def consolidar(self):
        if not self.archivos:
            messagebox.showwarning("Sin archivos", "Agrega archivos XLS primero.")
            return
        output = self.var_output.get().strip()
        if not output:
            messagebox.showwarning("Sin salida", "Define la ruta del archivo de salida.")
            return

        self.log("Iniciando consolidacion...")
        for f in self.archivos:
            self.log(f"  > {os.path.basename(f)}")

        try:
            df = consolidar(self.archivos)
            if df.empty:
                self.log("AVISO: No se encontraron datos.")
                messagebox.showwarning(
                    "Sin datos",
                    "No se pudieron extraer datos.\n"
                    "Verifica que el nombre del archivo incluya:\n"
                    "B-2401, B-3301, C-1301, C-2301 o C-4301"
                )
                return

            n_ind = len([c for c in df.columns if c not in
                         ["Tipo","Entidad","Periodo","Fecha Ratio Capital Global"]])
            self.log(f"OK - Entidades  : {len(df)}")
            self.log(f"OK - Indicadores: {n_ind}")
            exportar_excel(df, output)
            self.log(f"OK - Guardado en: {output}")
            messagebox.showinfo(
                "Consolidacion exitosa",
                f"Archivo guardado en:\n{output}\n\n"
                f"Entidades  : {len(df)}\n"
                f"Indicadores: {n_ind}\n\n"
                f"Hoja 1 - Tabla pivote (para analisis)\n"
                f"Hoja 2 - Formato largo (Para_SQL)"
            )
        except Exception as e:
            import traceback
            self.log(f"ERROR: {e}")
            self.log(traceback.format_exc())
            messagebox.showerror("Error", str(e))


